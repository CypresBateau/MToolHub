# 环境变量配置示例
# 复制此文件为 .env 并填入实际值

# Claude API
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# Gateway 配置
GATEWAY_BASE_URL=http://localhost:9000

# Embedding 模型
EMBEDDING_MODEL=pritamdeka/S-PubMedBert-MS-MARCO
EMBEDDING_DEVICE=cpu

# 应用配置
DEBUG=false
HOST=0.0.0.0
PORT=8080
